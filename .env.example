# SuperChat — variables de entorno opcionales.
# Copia este archivo a .env y descomenta/edita lo que necesites:
#   cp .env.example .env

# ── Acceso externo (VM / red local) ──────────────────────────────────────────
# IP o hostname que verán los clientes (otros equipos, móviles, etc.) cuando
# accedan al stack. Si dejas localhost, sólo funciona desde la misma máquina.
# Se inyecta en:
#   - docker-compose.yml -> KC_HOSTNAME
#   - keycloak/superchat-realm.json -> redirectUris (login OAuth2)
# PUBLIC_HOST=10.0.0.50

# ── Producción con dominio + HTTPS (perfil docker-compose.prod.yml) ─────────
# Dominio público apuntando a la VM. Caddy emite cert TLS de Let's Encrypt
# automáticamente para este dominio.
# PUBLIC_DOMAIN=chat.example.com

# Email para Let's Encrypt (avisos de expiración, recuperación). Si lo dejas
# vacío Caddy usa el modo "no-email" con menos garantías.
# ACME_EMAIL=admin@example.com

# Chat message encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
# REQUIRED in production — the default is intentionally weak
AES_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Internal service-to-service token (used for GDPR data export between services)
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=change_me_generate_with_openssl_rand_hex_32
