      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Anderson",
      "email": "alice@superchat.local",
      "credentials": [
        { "type": "password", "value": "demo123", "temporary": false }
      ],
      "realmRoles": ["user"]
    },
    {
