{
  "id": "superchat",
  "realm": "superchat",
  "displayName": "SuperChat",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "user", "description": "Standard user role" },
      { "name": "admin", "description": "Administrator role" }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "superchat-frontend",
      "name": "SuperChat Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8090/*",
        "http://${PUBLIC_HOST}:3000/*",
        "http://${PUBLIC_HOST}:8090/*",
        "https://${PUBLIC_DOMAIN}/*",
        "https://${PUBLIC_DOMAIN}:443/*"
      ],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*##http://${PUBLIC_HOST}:3000/*##https://${PUBLIC_DOMAIN}/*"
      }
    }
  ],
  "scopeMappings": [],
  "users": [
    {
